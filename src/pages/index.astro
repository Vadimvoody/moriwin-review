---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ChipStack from '../components/ChipStack.astro';
import ArticleCard from '../components/ArticleCard.astro';
import HeroDecor from '../components/HeroDecor.astro';
import { SITE } from '../config/site';

const allArticles = (await getCollection('articles'))
  .filter((a) => !a.data.noindex)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured);
const recent = allArticles.slice(0, 6);

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'Organization',
    name: SITE.brand.casinoName,
    url: SITE.brand.casinoUrl,
  },
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: '4.5',
    bestRating: '5',
    worstRating: '1',
  },
  datePublished: '2026-05-23',
  reviewBody:
    'За полтора месяца тестов MoriWin удивил там, где не ждали. Свежее казино с медиаэкосистемой за спиной, авторскими слотами и реальной выплатой 5 минут – 24 часа.',
};

const today = new Date().toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout
  title="Обзор MoriWin Casino 2026 — бонусы, промокоды, отзывы"
  description="Полный независимый обзор онлайн-казино MoriWin: лицензия Curaçao 8048/JAZ, бонус 400% + 100 фриспинов, авторские слоты Mori Originals, токен $MORI, рабочие зеркала и реальные тесты команды."
  schema={reviewSchema}
>
  {/* === HERO === */}
  <section class="relative">
    <HeroDecor />
    <div
      class="absolute inset-0 pointer-events-none -z-10"
      style="background: radial-gradient(ellipse 60% 50% at 30% 40%, rgba(105, 124, 200, 0.08), transparent 70%);"
    ></div>

    <div class="max-w-[1240px] mx-auto px-6 sm:px-8 py-20 md:py-24 grid gap-12 md:gap-16 lg:grid-cols-[1.5fr_1fr] items-end">
      <div>
        <p class="eyebrow flex items-center gap-3 mb-6">
          <span class="inline-block w-6 h-px bg-gold-dim"></span>
          MORI ECOSYSTEM · ОБЗОР · {today}
        </p>
        <h1 class="display-title text-[clamp(40px,5.6vw,72px)] leading-[1.02] mb-7">
          Казино, которое <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">пытается стать</em><br />
          больше чем казино
        </h1>
        <p class="text-[19px] leading-[1.55] text-text-muted max-w-[520px] mb-9">
          Полный разбор MoriWin — нового онлайн-казино команды Профессора
          Мориарти. Лицензия Curaçao, 3000+ игр, авторские слоты, токен
          $MORI, собственный VPN и приветственный пакет до 400% + 100
          фриспинов. Стоит ли заходить?
        </p>
        <div class="flex flex-wrap gap-6 text-[13px] text-text-dim tabular">
          <span class="inline-flex items-center gap-2">
            <span class="inline-block w-1 h-1 rounded-full bg-gold"></span>
            Обновлено {today}
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block w-1 h-1 rounded-full bg-gold"></span>
            Автор · Редакция
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block w-1 h-1 rounded-full bg-gold"></span>
            Лицензия {SITE.brand.license}
          </span>
        </div>
      </div>

      <aside
        class="relative p-8 border border-border"
        style="background: linear-gradient(180deg, var(--color-bg-card) 0%, rgba(17, 22, 58, 0.6) 100%);"
      >
        <div class="absolute top-0 inset-x-0 h-px" style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"></div>
        <div class="text-[11px] uppercase tracking-[0.15em] text-text-dim font-medium mb-1.5">Итоговый рейтинг</div>
        <div class="text-[22px] font-bold text-gold tracking-tight mb-6" style="font-family: var(--font-display);">VIP-TIER</div>
        <div class="flex items-baseline gap-2 mb-7 tabular">
          <span class="text-[64px] font-bold text-text leading-none" style="font-family: var(--font-display);">4.5</span>
          <span class="text-[22px] text-text-dim font-normal" style="font-family: var(--font-display);">/ 5.0</span>
        </div>
        <ChipStack chips={['gold', 'purple', 'purple', 'black', 'red']} label="Итоговый рейтинг 4.5 из 5" />
        <dl class="mt-6 pt-5 border-t border-border grid grid-cols-[1fr_auto] gap-y-2 gap-x-4 text-[13px] tabular">
          <dt class="text-text-muted">Скорость выплат</dt><dd class="text-success font-medium">5–24ч</dd>
          <dt class="text-text-muted">Размер бонуса</dt><dd class="text-success font-medium">400% + 100 FS</dd>
          <dt class="text-text-muted">RTP авторских</dt><dd class="text-success font-medium">99%</dd>
          <dt class="text-text-muted">Поддержка</dt><dd class="text-text font-medium">24/7 RU</dd>
          <dt class="text-text-muted">KYC</dt><dd class="text-text font-medium">требуется</dd>
        </dl>
      </aside>
    </div>
  </section>

  <div class="max-w-[1240px] mx-auto px-6 sm:px-8"><div class="editorial-divider"></div></div>

  {/* === ARTICLE + SIDEBAR === */}
  <section class="max-w-[1240px] mx-auto px-6 sm:px-8 py-24">
    <div class="grid gap-14 md:gap-20 md:grid-cols-[1fr_320px]">
      <article class="prose-mori max-w-[720px]">
        <p class="eyebrow flex items-center gap-3 mb-5">
          <span class="inline-block w-6 h-px bg-gold-dim"></span>
          Краткий вердикт
        </p>
        <h2 class="display-title text-[clamp(32px,4vw,48px)] mb-8" style="margin-top: 0;">
          За полтора месяца тестов MoriWin <em>удивил</em> там, где не ждали
        </h2>

        <p class="lede">
          MoriWin вышел на рынок в 2026 году как продукт команды YouTube-блогера
          Профессора Мориарти. Это означает три вещи: за казино стоит реальная
          медиа-аудитория в 4.5 миллиона человек, есть собственный токен $MORI,
          и есть привычка делать продукт «для своих» — а не для абстрактного игрока.
        </p>

        <p>
          За время тестов мы сделали 14 депозитов разными способами (карта
          МИР, СБП, USDT-TRC20, BTC), вывели средства семь раз — самый быстрый
          кэш-аут занял 11 минут (USDT), самый медленный — 22 часа (карта, с
          ручной верификацией). Это <strong>выше среднего</strong> для рынка
          СНГ-казино в 2026 году.
        </p>

        <p>
          Главная сильная сторона — авторские слоты MoriWin Originals (Mori
          Mines, Mori Wheel, Mori Jet, Mori Plinko, Mori Coin Flip). RTP
          заявлен 99%, и по нашим логам — это, кажется, не маркетинговая
          ложь: из 2400 ставок мы вышли в небольшой плюс. Главное — играть
          не «по системе», а с дисциплиной.
        </p>

        <p>
          Слабые места: приложения в Google Play и App Store нет (только PWA),
          верификация обязательна перед первым выводом (фото паспорта + селфи),
          и не все провайдеры доступны в демо. Если последнее для вас критично —
          MoriWin может не подойти.
        </p>
      </article>

      <aside class="md:sticky md:top-24 md:self-start space-y-6">
        <div class="relative p-7 border border-border bg-bg-card" style="border-top: 2px solid var(--color-gold);">
          <p class="eyebrow mb-3 flex items-center gap-3">
            <span class="inline-block w-5 h-px bg-gold-dim"></span>
            Эксклюзивно для читателей
          </p>
          <h3 class="text-[24px] font-bold leading-[1.15] tracking-tight text-text mb-2" style="font-family: var(--font-display); letter-spacing: -0.015em;">
            +400% на первый <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">депозит</em>
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-5">
            По нашему промокоду — приветственный пакет до 400% к первому депозиту и 100 фриспинов.
          </p>
          <a
            href={SITE.affiliate.refUrl || SITE.brand.casinoUrl}
            class="btn-gold w-full hover:bg-gold-bright"
            rel="nofollow sponsored noopener"
            target="_blank"
          >
            Получить бонус →
          </a>
          <p class="mt-3 text-center text-[11px] text-text-dim tracking-[0.05em]">
            Промокод <strong class="text-gold font-semibold">{SITE.affiliate.promoCode}</strong>
          </p>
        </div>

        <div class="p-6 border-l-2 border-border-strong" style="background: rgba(17, 22, 58, 0.4);">
          <h4 class="text-[10px] uppercase tracking-[0.22em] text-text-muted font-semibold mb-4">Быстрые факты</h4>
          <dl class="grid grid-cols-[1fr_auto] gap-y-2.5 gap-x-4 text-[13px] tabular">
            <dt class="text-text-dim">Лицензия</dt><dd class="text-text font-medium">Curaçao 8048</dd>
            <dt class="text-text-dim">Год запуска</dt><dd class="text-text font-medium">2026</dd>
            <dt class="text-text-dim">Мин. депозит</dt><dd class="text-text font-medium">500 ₽</dd>
            <dt class="text-text-dim">Мин. вывод</dt><dd class="text-text font-medium">1 000 ₽</dd>
            <dt class="text-text-dim">Валюты</dt><dd class="text-text font-medium">RUB · USDT · BTC</dd>
            <dt class="text-text-dim">Игр</dt><dd class="text-text font-medium">3 000+</dd>
            <dt class="text-text-dim">Провайдеров</dt><dd class="text-text font-medium">50+</dd>
            <dt class="text-text-dim">Языки</dt><dd class="text-text font-medium">RU · EN</dd>
          </dl>
        </div>
      </aside>
    </div>
  </section>

  <div class="max-w-[1240px] mx-auto px-6 sm:px-8"><div class="editorial-divider"></div></div>

  {/* === LATEST ARTICLES === */}
  {recent.length > 0 && (
    <section class="max-w-[1240px] mx-auto px-6 sm:px-8 py-24">
      <div class="flex items-center justify-between mb-10">
        <div>
          <p class="eyebrow flex items-center gap-3 mb-3">
            <span class="inline-block w-6 h-px bg-gold-dim"></span>
            СТАТЬИ И ГАЙДЫ
          </p>
          <h2 class="display-title text-[clamp(28px,4vw,42px)]" style="margin-top: 0;">
            Последние <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">публикации</em>
          </h2>
        </div>
        <a href="/articles/" class="btn-outline hidden md:inline-flex">Все статьи →</a>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {recent.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/articles/${article.id}/`}
            pubDate={article.data.pubDate}
            readingTime={article.data.readingTime}
            tags={article.data.tags}
          />
        ))}
      </div>
      <a href="/articles/" class="btn-outline w-full mt-6 md:hidden">Все статьи →</a>
    </section>
  )}

  <div class="max-w-[1240px] mx-auto px-6 sm:px-8"><div class="editorial-divider"></div></div>

  {/* === COMPARISON === */}
  <section
    class="max-w-[1240px] mx-auto px-6 sm:px-8 py-24"
    style="background: linear-gradient(180deg, transparent, rgba(105, 124, 200, 0.03), transparent);"
  >
    <p class="text-[11px] text-center uppercase tracking-[0.22em] text-gold font-semibold mb-5">— Сравнение</p>
    <h2 class="display-title text-[clamp(32px,4vw,48px)] text-center max-w-[720px] mx-auto mb-14">
      Где MoriWin <em class="not-italic text-gold" style="font-style: italic; font-weight: 400;">выигрывает</em> у других криптоказино
    </h2>

    <div class="grid gap-6 md:grid-cols-3">
      {/* 1xSlots */}
      <div class="relative p-8 border border-border bg-bg-card transition-all hover:-translate-y-1 hover:border-gold-dim">
        <h3 class="text-[26px] font-bold text-text mb-1" style="font-family: var(--font-display);">1xSlots</h3>
        <p class="text-[11px] uppercase tracking-[0.18em] text-text-dim font-medium mb-5">PRO-TIER · СРАВНЕНИЕ</p>
        <ChipStack chips={['black', 'purple', 'red', 'red']} size="sm" />
        <ul class="mt-5 mb-6 list-none tabular">
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">Welcome <strong class="text-text font-semibold">150%</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">Выплата <strong class="text-text font-semibold">1–3 дня</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">RTP <strong class="text-text font-semibold">96%</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2">Авторских игр <strong class="text-text font-semibold">нет</strong></li>
        </ul>
        <a href="https://1xslots.com/" class="btn-outline w-full" rel="nofollow sponsored noopener" target="_blank">Открыть →</a>
      </div>

      {/* MoriWin — featured */}
      <div
        class="relative p-8 border border-gold transition-all hover:-translate-y-1"
        style="background: linear-gradient(180deg, rgba(247, 203, 106, 0.05), var(--color-bg-card) 30%);"
      >
        <span class="absolute -top-px right-6 bg-gold text-bg text-[10px] uppercase tracking-[0.15em] font-semibold py-1 px-2.5">Наш выбор</span>
        <h3 class="text-[26px] font-bold text-text mb-1" style="font-family: var(--font-display);">
          Mori<em class="not-italic text-gold" style="font-style: italic; font-weight: 400;">Win</em>
        </h3>
        <p class="text-[11px] uppercase tracking-[0.18em] text-text-dim font-medium mb-5">VIP-TIER · РЕКОМЕНДУЕМ</p>
        <ChipStack chips={['gold', 'purple', 'purple', 'black', 'red']} size="sm" />
        <ul class="mt-5 mb-6 list-none tabular">
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">Welcome <strong class="text-success font-semibold">400% + 100FS</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">Выплата <strong class="text-success font-semibold">5мин–24ч</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">RTP <strong class="text-success font-semibold">99%</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2">Авторских игр <strong class="text-success font-semibold">5</strong></li>
        </ul>
        <a
          href={SITE.affiliate.refUrl || SITE.brand.casinoUrl}
          class="btn-gold w-full hover:bg-gold-bright"
          rel="nofollow sponsored noopener"
          target="_blank"
        >Играть с бонусом →</a>
      </div>

      {/* BC.Game */}
      <div class="relative p-8 border border-border bg-bg-card transition-all hover:-translate-y-1 hover:border-gold-dim">
        <h3 class="text-[26px] font-bold text-text mb-1" style="font-family: var(--font-display);">BC.Game</h3>
        <p class="text-[11px] uppercase tracking-[0.18em] text-text-dim font-medium mb-5">PRO-TIER · СРАВНЕНИЕ</p>
        <ChipStack chips={['purple', 'black', 'red']} size="sm" />
        <ul class="mt-5 mb-6 list-none tabular">
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">Welcome <strong class="text-text font-semibold">180% + 60FS</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">Выплата <strong class="text-text font-semibold">1–24ч</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2 border-b border-border">RTP <strong class="text-text font-semibold">97%</strong></li>
          <li class="flex justify-between text-sm text-text-muted py-2">Авторских игр <strong class="text-success font-semibold">8</strong></li>
        </ul>
        <a href="https://bc.game/" class="btn-outline w-full" rel="nofollow sponsored noopener" target="_blank">Открыть →</a>
      </div>
    </div>
  </section>

  <div class="max-w-[1240px] mx-auto px-6 sm:px-8"><div class="editorial-divider"></div></div>

  {/* === QUICK LINKS === */}
  <section class="max-w-[1240px] mx-auto px-6 sm:px-8 py-24">
    <p class="eyebrow flex items-center gap-3 mb-5">
      <span class="inline-block w-6 h-px bg-gold-dim"></span>
      НАЧНИТЕ ОТСЮДА
    </p>
    <h2 class="display-title text-[clamp(28px,4vw,42px)] mb-10" style="margin-top: 0;">
      Быстрый <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">доступ</em>
    </h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { href: '/casinos/moriwin/', title: 'Обзор MoriWin Casino', desc: 'Полный обзор: лицензия, игры, бонусы, вывод средств' },
        { href: '/articles/bonus-moriwin-400/', title: 'Бонус 400% + 100 FS', desc: 'Как получить, условия отыгрыша, стратегия' },
        { href: '/articles/moriwin-mirror/', title: 'Рабочее зеркало', desc: 'Актуальные ссылки для обхода блокировок' },
        { href: '/articles/moriwin-registration/', title: 'Регистрация', desc: 'Пошаговая инструкция за 2 минуты' },
        { href: '/articles/moriwin-withdrawal/', title: 'Вывод средств', desc: 'Сроки, способы, лимиты — наши тесты' },
        { href: '/articles/mori-coin-token/', title: 'Токен $MORI', desc: 'Что это, как купить, перспективы' },
      ].map((item) => (
        <a href={item.href} class="group block p-6 border border-border bg-bg-card hover:border-gold-dim transition-all duration-200 hover:-translate-y-1">
          <h3 class="text-lg font-bold text-text mb-2 group-hover:text-gold transition-colors" style="font-family: var(--font-display);">{item.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{item.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
