---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SectionDecor from '../../components/SectionDecor.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbSchema, buildFaqSchema } from '../../lib/seo';

const allBonuses = (await getCollection('bonuses'))
  .filter((b) => !b.data.noindex)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Бонусы', href: '/bonus/' },
];
const faqItems = [
  {
    question: 'Есть ли актуальный промокод MoriWin?',
    answer: 'Сейчас на сайте указан промокод MORIBONUS. Финальную партнёрскую ссылку добавим после подтверждения менеджера.',
  },
  {
    question: 'На что смотреть перед активацией бонуса?',
    answer: 'Проверяйте wagering, минимальный депозит, срок действия бонуса и максимальную ставку при отыгрыше.',
  },
];
const schemas = [buildBreadcrumbSchema(breadcrumbs), buildFaqSchema(faqItems)];
---

<Layout
  title="Бонусы и промокоды MoriWin — актуальные предложения 2026"
  description="Все действующие бонусы и промокоды казино MoriWin: приветственный пакет 400% + 100 FS, кэшбэк, фриспины и эксклюзивные предложения."
  schema={schemas}
>
  <div class="relative overflow-hidden">
    <SectionDecor leftText="BONUS" rightText="400%" />
    <section class="max-w-[1240px] mx-auto px-6 sm:px-8 py-20 md:py-24 relative z-10">
    <Breadcrumbs items={breadcrumbs} />
    <p class="eyebrow flex items-center gap-3 mb-5">
      <span class="inline-block w-6 h-px bg-gold-dim"></span>
      БОНУСЫ И ПРОМОКОДЫ
    </p>
    <h1
      class="display-title text-[clamp(36px,5vw,56px)] mb-10"
      style="margin-top: 0;"
    >
      Актуальные бонусы <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">MoriWin</em>
    </h1>
    <p class="text-[18px] leading-[1.6] text-text-muted max-w-[760px] mb-12">
      На этой странице собраны бонусы MoriWin, которые стоит проверять перед депозитом: приветственный пакет, кэшбэк и ежедневные акции. Мы отдельно показываем промокод, отыгрыш и минимальные условия, чтобы предложение было понятно до перехода в казино.
    </p>

    {allBonuses.length === 0 && (
      <div class="py-20 text-center">
        <p class="text-2xl text-text-muted mb-4" style="font-family: var(--font-display); font-style: italic;">
          Бонусов пока нет
        </p>
        <p class="text-sm text-text-dim">Мы собираем актуальные предложения. Следите за обновлениями.</p>
      </div>
    )}

    {allBonuses.length > 0 && (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {allBonuses.map((bonus) => (
          <div class="relative p-6 border border-border bg-bg-card transition-all duration-200 hover:-translate-y-1 hover:border-gold-dim">
            {bonus.data.featured && (
              <span class="absolute -top-px right-6 bg-gold text-bg text-[10px] uppercase tracking-[0.15em] font-semibold py-1 px-2.5">
                Акция
              </span>
            )}
            <p class="text-[11px] uppercase tracking-[0.18em] text-text-dim font-medium mb-3">
              {bonus.data.bonusType.replace('-', ' ')}
            </p>
            <h3 class="text-xl font-bold text-text mb-2" style="font-family: var(--font-display);">
              {bonus.data.title}
            </h3>
            <p class="text-3xl font-bold text-gold mb-3 tabular" style="font-family: var(--font-display);">
              {bonus.data.amount}
            </p>
            {bonus.data.promoCode && (
              <p class="text-sm text-text-muted mb-3">
                Промокод: <strong class="text-gold font-semibold">{bonus.data.promoCode}</strong>
              </p>
            )}
            {bonus.data.wagering && (
              <p class="text-xs text-text-dim mb-4">Отыгрыш: {bonus.data.wagering}</p>
            )}
            <a
              href={bonus.data.referralUrl}
              class="btn-gold w-full hover:bg-gold-bright text-center"
              rel="nofollow sponsored noopener"
              target="_blank"
            >
              Получить бонус →
            </a>
          </div>
        ))}
      </div>
    )}
    <div class="mt-16 grid gap-4 md:grid-cols-2">
      {faqItems.map((item) => (
        <div class="p-6 border border-border bg-bg-card">
          <h2 class="text-lg font-bold text-text mb-3" style="font-family: var(--font-display);">{item.question}</h2>
          <p class="text-sm text-text-muted leading-relaxed">{item.answer}</p>
        </div>
      ))}
    </div>
  </section>
  </div>
</Layout>
