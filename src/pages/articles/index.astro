---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import SectionDecor from '../../components/SectionDecor.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbSchema, buildFaqSchema } from '../../lib/seo';

const allArticles = (await getCollection('articles'))
  .filter((a) => !a.data.noindex)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured);
const recent = allArticles.slice(0, 12);
const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Статьи', href: '/articles/' },
];
const faqItems = [
  {
    question: 'Какие гайды по MoriWin стоит читать в первую очередь?',
    answer: 'Начните с обзора казино, бонуса 400% + 100 FS, регистрации, вывода средств и рабочего зеркала. Эти материалы закрывают основные действия нового игрока.',
  },
  {
    question: 'Как часто обновляются статьи?',
    answer: 'Мы обновляем материалы при изменении бонусов, зеркал, условий вывода или важных деталей экосистемы MoriWin.',
  },
];
const schemas = [buildBreadcrumbSchema(breadcrumbs), buildFaqSchema(faqItems)];
---

<Layout
  title="Статьи и гайды по MoriWin — обзоры, новости, инструкции"
  description="Все статьи и гайды по казино MoriWin: как зарегистрироваться, внести депозит, вывести деньги, использовать бонусы и промокоды. Регулярные обновления."
  schema={schemas}
>
  <div class="relative overflow-hidden">
    <SectionDecor leftText="GUIDES" rightText="2026" />
    <section class="max-w-[1240px] mx-auto px-6 sm:px-8 py-20 md:py-24 relative z-10">
    <Breadcrumbs items={breadcrumbs} />
    <p class="eyebrow flex items-center gap-3 mb-5">
      <span class="inline-block w-6 h-px bg-gold-dim"></span>
      ВСЕ СТАТЬИ
    </p>
    <h1
      class="display-title text-[clamp(36px,5vw,56px)] mb-10"
      style="margin-top: 0;"
    >
      Гайды, обзоры <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">и новости</em>
    </h1>
    <p class="text-[18px] leading-[1.6] text-text-muted max-w-[760px] mb-12">
      Здесь собраны практические материалы по MoriWin: от регистрации и бонусов до вывода средств, зеркал, MoriVPN и токена $MORI. Мы связываем инструкции между собой, чтобы новый игрок мог быстро пройти путь от первого входа до безопасного вывода.
    </p>

    {allArticles.length === 0 && (
      <div class="py-20 text-center">
        <p class="text-2xl text-text-muted mb-4" style="font-family: var(--font-display); font-style: italic;">
          Статей пока нет
        </p>
        <p class="text-sm text-text-dim">Мы готовим контент. Следите за обновлениями.</p>
      </div>
    )}

    {featured.length > 0 && (
      <div class="mb-16">
        <p class="eyebrow flex items-center gap-3 mb-5">
          <span class="inline-block w-6 h-px bg-gold-dim"></span>
          РЕКОМЕНДУЕМ
        </p>
        <div class="grid gap-4 md:grid-cols-2">
          {featured.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/articles/${article.id}/`}
              pubDate={article.data.pubDate}
              readingTime={article.data.readingTime}
              tags={article.data.tags}
            />
          ))}
        </div>
      </div>
    )}

    {recent.length > 0 && (
      <div>
        <p class="eyebrow flex items-center gap-3 mb-5">
          <span class="inline-block w-6 h-px bg-gold-dim"></span>
          ПОСЛЕДНИЕ
        </p>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {recent.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/articles/${article.id}/`}
              pubDate={article.data.pubDate}
              readingTime={article.data.readingTime}
              tags={article.data.tags}
            />
          ))}
        </div>
      </div>
    )}
    <div class="mt-16 grid gap-4 md:grid-cols-2">
      {faqItems.map((item) => (
        <div class="p-6 border border-border bg-bg-card">
          <h2 class="text-lg font-bold text-text mb-3" style="font-family: var(--font-display);">{item.question}</h2>
          <p class="text-sm text-text-muted leading-relaxed">{item.answer}</p>
        </div>
      ))}
    </div>
  </section>
  </div>
</Layout>
