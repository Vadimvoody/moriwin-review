---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import SectionDecor from '../../components/SectionDecor.astro';

const allArticles = (await getCollection('articles'))
  .filter((a) => !a.data.noindex)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured);
const recent = allArticles.slice(0, 12);
---

<Layout
  title="Статьи и гайды по MoriWin — обзоры, новости, инструкции"
  description="Все статьи и гайды по казино MoriWin: как зарегистрироваться, внести депозит, вывести деньги, использовать бонусы и промокоды. Регулярные обновления."
>
  <div class="relative overflow-hidden">
    <SectionDecor leftText="GUIDES" rightText="2026" />
    <section class="max-w-[1240px] mx-auto px-6 sm:px-8 py-20 md:py-24 relative z-10">
    <p class="eyebrow flex items-center gap-3 mb-5">
      <span class="inline-block w-6 h-px bg-gold-dim"></span>
      ВСЕ СТАТЬИ
    </p>
    <h1
      class="display-title text-[clamp(36px,5vw,56px)] mb-10"
      style="margin-top: 0;"
    >
      Гайды, обзоры <em class="text-gold not-italic" style="font-style: italic; font-weight: 400;">и новости</em>
    </h1>

    {allArticles.length === 0 && (
      <div class="py-20 text-center">
        <p class="text-2xl text-text-muted mb-4" style="font-family: var(--font-display); font-style: italic;">
          Статей пока нет
        </p>
        <p class="text-sm text-text-dim">Мы готовим контент. Следите за обновлениями.</p>
      </div>
    )}

    {featured.length > 0 && (
      <div class="mb-16">
        <p class="eyebrow flex items-center gap-3 mb-5">
          <span class="inline-block w-6 h-px bg-gold-dim"></span>
          РЕКОМЕНДУЕМ
        </p>
        <div class="grid gap-4 md:grid-cols-2">
          {featured.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/articles/${article.id}/`}
              pubDate={article.data.pubDate}
              readingTime={article.data.readingTime}
              tags={article.data.tags}
            />
          ))}
        </div>
      </div>
    )}

    {recent.length > 0 && (
      <div>
        <p class="eyebrow flex items-center gap-3 mb-5">
          <span class="inline-block w-6 h-px bg-gold-dim"></span>
          ПОСЛЕДНИЕ
        </p>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {recent.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/articles/${article.id}/`}
              pubDate={article.data.pubDate}
              readingTime={article.data.readingTime}
              tags={article.data.tags}
            />
          ))}
        </div>
      </div>
    )}
  </section>
  </div>
</Layout>
