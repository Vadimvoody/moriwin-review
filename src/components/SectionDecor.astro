---
/**
 * Декор для секций — фоновая типографика по бокам + редкие фишки (8 штук на секцию).
 * Только для xl+ экранов (1280px+).
 */
interface Props {
  leftText?: string;
  rightText?: string;
  leftColor?: string;
  rightColor?: string;
  leftItalic?: boolean;
  rightItalic?: boolean;
  /** Дополнительные фишки — 'none', 'few' (4), 'many' (8) */
  chips?: 'none' | 'few' | 'many';
}

const {
  leftText,
  rightText,
  leftColor = 'rgba(247, 203, 106, 0.04)',
  rightColor = 'rgba(105, 124, 200, 0.045)',
  leftItalic = false,
  rightItalic = false,
  chips = 'many',
} = Astro.props;
---

<div class="hidden xl:block absolute inset-0 pointer-events-none overflow-hidden -z-10" aria-hidden="true">
  {leftText && (
    <div
      class="absolute top-[15%] -left-[2%] text-[clamp(140px,14vw,260px)] font-bold leading-none tracking-tighter select-none"
      style={`font-family: var(--font-display); color: ${leftColor}; letter-spacing: -0.05em; ${leftItalic ? 'font-style: italic; font-weight: 400;' : ''}`}
    >
      {leftText}
    </div>
  )}

  {rightText && (
    <div
      class="absolute bottom-[10%] -right-[2%] text-[clamp(160px,16vw,280px)] font-bold leading-none tracking-tighter select-none"
      style={`font-family: var(--font-display); color: ${rightColor}; letter-spacing: -0.05em; ${rightItalic ? 'font-style: italic; font-weight: 400;' : ''}`}
    >
      {rightText}
    </div>
  )}

  {/* === CHIPS === */}
  {chips !== 'none' && (
    <>
      {/* Top-left gold */}
      <svg class="chip-float absolute" style="top: 12%; left: 1%; width: 80px; height: 80px; opacity: 0.16; animation-delay: 0.3s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#d4a836" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#d4a836" stroke-width="0.8" opacity="0.5"/><text x="24" y="28" text-anchor="middle" fill="#d4a836" font-size="8" font-weight="600" font-family="Manrope, sans-serif">$1K</text></svg>

      {/* Top-right purple */}
      <svg class="chip-float-alt absolute" style="top: 8%; right: 2%; width: 70px; height: 70px; opacity: 0.14; animation-delay: 1.7s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#6b46c1" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#6b46c1" stroke-width="0.8" opacity="0.5"/></svg>

      {/* Mid-left small black */}
      <svg class="chip-float absolute" style="top: 40%; left: -1%; width: 55px; height: 55px; opacity: 0.18; animation-delay: 2.1s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#4a5568" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#4a5568" stroke-width="0.8" opacity="0.5"/><text x="24" y="28" text-anchor="middle" fill="#718096" font-size="8" font-weight="600" font-family="Manrope, sans-serif">$100</text></svg>

      {/* Mid-right red */}
      <svg class="chip-float-alt absolute" style="top: 55%; right: 0%; width: 60px; height: 60px; opacity: 0.16; animation-delay: 3.4s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#c53030" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#c53030" stroke-width="0.8" opacity="0.5"/><text x="24" y="28" text-anchor="middle" fill="#c53030" font-size="8" font-weight="600" font-family="Manrope, sans-serif">$5</text></svg>

      {/* Bottom-left gold */}
      <svg class="chip-float absolute" style="bottom: 15%; left: 2%; width: 90px; height: 90px; opacity: 0.14; animation-delay: 4.2s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#d4a836" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#d4a836" stroke-width="0.8" opacity="0.5"/></svg>

      {/* Bottom-right purple */}
      <svg class="chip-float-alt absolute" style="bottom: 8%; right: 1%; width: 100px; height: 100px; opacity: 0.12; animation-delay: 0.8s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#6b46c1" stroke-width="1" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#6b46c1" stroke-width="0.5" opacity="0.5"/></svg>
    </>
  )}

  {chips === 'many' && (
    <>
      {/* Extra: tiny accent top-center-left */}
      <svg class="chip-float absolute" style="top: 25%; left: 8%; width: 35px; height: 35px; opacity: 0.2; animation-delay: 5s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#d4a836" stroke-width="2" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#d4a836" stroke-width="1" opacity="0.5"/><text x="24" y="28" text-anchor="middle" fill="#d4a836" font-size="8" font-weight="600" font-family="Manrope, sans-serif">VIP</text></svg>

      {/* Extra: tiny accent bottom-center-right */}
      <svg class="chip-float-alt absolute" style="bottom: 30%; right: 6%; width: 40px; height: 40px; opacity: 0.18; animation-delay: 2.6s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#c53030" stroke-width="2" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#c53030" stroke-width="1" opacity="0.5"/></svg>
    </>
  )}
</div>
