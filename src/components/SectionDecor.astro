---
/**
 * Декор для секций — фоновая типографика по бокам + фишки.
 * Типографика — только xl+ (1280px+). Фишки — на всех экранах.
 */
interface Props {
  leftText?: string;
  rightText?: string;
  leftColor?: string;
  rightColor?: string;
  leftItalic?: boolean;
  rightItalic?: boolean;
  chips?: 'none' | 'few' | 'many';
}

const {
  leftText,
  rightText,
  leftColor = 'rgba(247, 203, 106, 0.04)',
  rightColor = 'rgba(105, 124, 200, 0.045)',
  leftItalic = false,
  rightItalic = false,
  chips = 'many',
} = Astro.props;
---

<div class="absolute inset-0 pointer-events-none overflow-hidden -z-10" aria-hidden="true">
  {/* Background typography — xl+ only */}
  {leftText && (
    <div
      class="hidden xl:block absolute top-[15%] -left-[2%] text-[clamp(140px,14vw,260px)] font-bold leading-none tracking-tighter select-none"
      style={`font-family: var(--font-display); color: ${leftColor}; letter-spacing: -0.05em; ${leftItalic ? 'font-style: italic; font-weight: 400;' : ''}`}
    >
      {leftText}
    </div>
  )}

  {rightText && (
    <div
      class="hidden xl:block absolute bottom-[10%] -right-[2%] text-[clamp(160px,16vw,280px)] font-bold leading-none tracking-tighter select-none"
      style={`font-family: var(--font-display); color: ${rightColor}; letter-spacing: -0.05em; ${rightItalic ? 'font-style: italic; font-weight: 400;' : ''}`}
    >
      {rightText}
    </div>
  )}

  {/* === CHIPS — visible on all screens === */}
  {chips !== 'none' && (
    <>
      {/* Top-left gold — big on xl, smaller on mobile */}
      <svg class="chip-float absolute w-10 h-10 xl:w-[80px] xl:h-[80px] opacity-10 xl:opacity-[0.16]" style="top: 12%; left: 1%; animation-delay: 0.3s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#d4a836" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#d4a836" stroke-width="0.8" opacity="0.5"/><text x="24" y="28" text-anchor="middle" fill="#d4a836" font-size="8" font-weight="600" font-family="Manrope, sans-serif" class="hidden xl:inline">$1K</text></svg>

      {/* Top-right purple */}
      <svg class="chip-float-alt absolute w-8 h-8 xl:w-[70px] xl:h-[70px] opacity-[0.08] xl:opacity-[0.14]" style="top: 8%; right: 2%; animation-delay: 1.7s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#6b46c1" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#6b46c1" stroke-width="0.8" opacity="0.5"/></svg>

      {/* Mid-left black */}
      <svg class="chip-float absolute w-7 h-7 xl:w-[55px] xl:h-[55px] opacity-[0.08] xl:opacity-[0.18]" style="top: 40%; left: -1%; animation-delay: 2.1s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#4a5568" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#4a5568" stroke-width="0.8" opacity="0.5"/></svg>

      {/* Mid-right red */}
      <svg class="chip-float-alt absolute w-8 h-8 xl:w-[60px] xl:h-[60px] opacity-[0.08] xl:opacity-[0.16]" style="top: 55%; right: 0%; animation-delay: 3.4s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#c53030" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#c53030" stroke-width="0.8" opacity="0.5"/></svg>

      {/* Bottom-left gold */}
      <svg class="chip-float absolute w-9 h-9 xl:w-[90px] xl:h-[90px] opacity-10 xl:opacity-[0.14]" style="bottom: 15%; left: 2%; animation-delay: 4.2s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#d4a836" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#d4a836" stroke-width="0.8" opacity="0.5"/></svg>

      {/* Bottom-right purple */}
      <svg class="chip-float-alt absolute w-10 h-10 xl:w-[100px] xl:h-[100px] opacity-[0.08] xl:opacity-[0.12]" style="bottom: 8%; right: 1%; animation-delay: 0.8s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#6b46c1" stroke-width="1" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#6b46c1" stroke-width="0.5" opacity="0.5"/></svg>
    </>
  )}

  {chips === 'many' && (
    <>
      {/* Extra tiny gold accent */}
      <svg class="chip-float absolute w-6 h-6 xl:w-[35px] xl:h-[35px] opacity-[0.12] xl:opacity-[0.2]" style="top: 25%; left: 8%; animation-delay: 5s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#d4a836" stroke-width="2" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#d4a836" stroke-width="1" opacity="0.5"/></svg>

      {/* Extra tiny red accent */}
      <svg class="chip-float-alt absolute w-6 h-6 xl:w-[40px] xl:h-[40px] opacity-[0.1] xl:opacity-[0.18]" style="bottom: 30%; right: 6%; animation-delay: 2.6s;" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#c53030" stroke-width="2" stroke-dasharray="4 3"/><circle cx="24" cy="24" r="16" stroke="#c53030" stroke-width="1" opacity="0.5"/></svg>
    </>
  )}
</div>
